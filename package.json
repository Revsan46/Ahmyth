{
  "name": "rtchat-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "packageManager": "npm@10",
  "scripts": {
    "build": "npm -ws run build",
    "typecheck": "npm -ws run typecheck",
    "dev:server": "npm --workspace server run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "lint": "echo 'TODO: add lints'"
  }
}